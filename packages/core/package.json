{
  "name": "@steipete/summarize-core",
  "version": "0.18.0",
  "description": "Summarize core library (content extraction + prompts).",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    },
    "./content": {
      "types": "./dist/types/content/index.d.ts",
      "import": "./dist/esm/content/index.js"
    },
    "./content/url": {
      "types": "./dist/types/content/url.d.ts",
      "import": "./dist/esm/content/url.js"
    },
    "./content/local-file": {
      "types": "./dist/types/content/local-file.d.ts",
      "import": "./dist/esm/content/local-file.js"
    },
    "./content/youtube": {
      "types": "./dist/types/content/youtube.d.ts",
      "import": "./dist/esm/content/youtube.js"
    },
    "./prompts": {
      "types": "./dist/types/prompts/index.d.ts",
      "import": "./dist/esm/prompts/index.js"
    },
    "./processes": {
      "types": "./dist/types/processes.d.ts",
      "import": "./dist/esm/processes.js"
    },
    "./language": {
      "types": "./dist/types/language.d.ts",
      "import": "./dist/esm/language.js"
    },
    "./ffmpeg": {
      "types": "./dist/types/ffmpeg.d.ts",
      "import": "./dist/esm/ffmpeg.js"
    }
  },
  "scripts": {
    "build": "pnpm clean && tsgo -p tsconfig.build.json && node scripts/package-ffmpeg-wasm.mjs",
    "clean": "rimraf dist",
    "prepublishOnly": "node ../../scripts/require-pnpm-publish.mjs",
    "typecheck": "tsgo -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "linkedom": "^0.18.12",
    "sanitize-html": "^2.17.4",
    "undici": "8.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@types/sanitize-html": "^2.16.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2"
}
